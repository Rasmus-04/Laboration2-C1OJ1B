<Window x:Class="Laboration_2.Vy.AddSpelWindow.AddSpel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laboration_2.Vy.AddSpelWindow"
        mc:Ignorable="d" WindowStyle="None" WindowStartupLocation="CenterOwner"
        Title="AddSpel" Height="230" Width="220">
    <Grid>
        <StackPanel>
            <Label Content="Spel titel"/>
            <TextBox Name="txtTitel" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0"/>
            <Label Content="Max Spelare"/>
            <TextBox Name="maxPlayers" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0"/>
            <Label Content="Min seplare"/>
            <TextBox Name="minPlayers" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Lägg Till" Margin="5,10,0,0" Width="60" HorizontalAlignment="Left" Name="AddUserBtn" Click="AddUserBtn_Click"/>
                <Button Content="Avbryt" Margin="5,10,0,0" Width="60" HorizontalAlignment="Left" Name="CancelBtn" Click="CancelBtn_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
