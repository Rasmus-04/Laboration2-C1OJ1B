<Window x:Class="Laboration_2.View.Windows.CreateGameWindow.CreateGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laboration_2.View.Windows.CreateGameWindow"
        mc:Ignorable="d" WindowStyle="None" WindowStartupLocation="CenterOwner"
        Title="AddSpel" Height="230" Width="220">
    <Grid>
        <StackPanel>
            <Label Content="Spel titel"/>
            <TextBox Name="txtTitel" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0" Text="{Binding TbTitel, UpdateSourceTrigger=PropertyChanged}"/>
            <Label Content="Max Spelare"/>
            <TextBox Name="maxPlayers" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0" Text="{Binding TbMaxPlayers, UpdateSourceTrigger=PropertyChanged}"/>
            <Label Content="Min seplare"/>
            <TextBox Name="minPlayers" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0" Text="{Binding TbMinPlayers, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="{Binding ButtonText}" Margin="5,10,0,0" Width="60" HorizontalAlignment="Left" Name="btnCreateGame" Command="{Binding btnCreateGame}"/>
                <Button Content="Avbryt" Margin="5,10,0,0" Width="60" HorizontalAlignment="Left" Name="CancelBtn" Command="{Binding btnCloseWindow}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
