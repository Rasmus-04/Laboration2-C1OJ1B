<Window x:Class="Laboration_2.View.Windows.RegisterMemberWindow.RegisterMemberWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laboration_2.View.Windows.RegisterMemberWindow"
        mc:Ignorable="d" WindowStyle="None" WindowStartupLocation="CenterOwner"
        Title="AddMember" Height="230" Width="220">
    <Grid>
        <StackPanel>
            <Label Content="Namn"/>
            <TextBox Name="txtName" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
            <Label Content="Ålder"/>
            <TextBox Name="txtAge" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0" Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}"/>
            <Label Content="Epost"/>
            <TextBox Name="txtEmail" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="{Binding ButtonText}" Margin="5,10,0,0" Width="60" HorizontalAlignment="Left" Name="AddUserBtn" Command="{Binding btnAddUserCommand}"/>
                <Button Content="Avbryt" Margin="5,10,0,0" Width="60" HorizontalAlignment="Left" Name="CancelBtn" Command="{Binding btnCloseWindow}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
