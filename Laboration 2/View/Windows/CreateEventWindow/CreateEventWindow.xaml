<Window x:Class="Laboration_2.View.Windows.CreateEventWindow.CreateEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laboration_2.View.Windows.CreateEventWindow"
        mc:Ignorable="d" WindowStyle="None" WindowStartupLocation="CenterOwner"
        Title="AddEvent" Height="250" Width="220">
    <Grid>
        <StackPanel>
            <Label Content="Namn på aktivitet"/>
            <TextBox Name="txtTitel" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0"/>
            <Label Content="Datum"/>
            <DatePicker Name="datePicker" Margin="0,0,0,0" Width="200"/>
            <Label Content="Max Deltagare"/>
            <TextBox Name="txtMaxDeltagare" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0"/>
            <Label Content="Spel"/>
            <ComboBox Name="cbSpel" Width="200" HorizontalAlignment="Left" Margin="5,0,0,0" DisplayMemberPath="Titel"/>
            
            
            <StackPanel Orientation="Horizontal" Margin="0,10">
                <Button Content="Lägg Till" Margin="5" Name="btnAddEvent" Click="btnAddEvent_Click"/>
                <Button Content="Avbryt" Margin="5" Name="Cancel" Click="Cancel_Click"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>
