<Window x:Class="Laboration_2.View.Windows.AddMemberToEventWindow.AddMemberToEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laboration_2.View.Windows.AddMemberToEventWindow"
        mc:Ignorable="d" WindowStyle="None" WindowStartupLocation="CenterOwner"
        Title="AddDeltagareWindow" Height="380" Width="340">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>

        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Vertical" Grid.Column="0">
                <TextBlock Text="Titel: chess tunering" Name="tbTitel"/>
                <TextBlock Text="Spel: Chess" Name="tbSpel"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="Datum: 02/06/2026" Name="tbDatum"/>
                <TextBlock Text="Deltagare 10/30" Name="tbDeltagare"/>
            </StackPanel>
        </Grid>
        <StackPanel Orientation="Vertical" Grid.Row="1">
            <Label Content="Välj Medlem"/>
            <ComboBox Name="cbMedlem" Width="320"  HorizontalAlignment="Left" Margin="5,0,0,0" DisplayMemberPath="Name"/>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" Margin="5" Grid.Row="2">
            <Button Content="Lägg Till" Margin="5" Height="30" Name="btnAddMember" Click="btnAddMember_Click"/>
            <Button Content="Avbryt" Margin="5" Height="30" Name="btnCancel" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
