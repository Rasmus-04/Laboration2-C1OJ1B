<UserControl x:Class="Laboration_2.View.UserControls.EventListView.EventListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Laboration_2.View.UserControls.EventListView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        <ListView ItemsSource="{Binding AllEvents}" Name="lvAktiviteter" SelectionMode="Single" SelectedItem="{Binding SelectedEventItem}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Namn" DisplayMemberBinding="{Binding Name}" Width="75"/>
                    <GridViewColumn Header="Datum" DisplayMemberBinding="{Binding EventDate}" Width="75"/>
                    <GridViewColumn Header="Spel" DisplayMemberBinding="{Binding EventGame.Titel}" Width="75" />
                    <GridViewColumn Header="Antal Deltagare" DisplayMemberBinding="{Binding CurrentParticipants}" Width="90" />

                </GridView>
            </ListView.View>
        </ListView>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal"
                Grid.Row="0"
                Margin="5">

                <Button Content="Lägg Till Deltagare"
                    Command="{Binding btnAddMemberToEvent}"
                    Width="150"
                    Margin="0,0,10,0"/>

                <Button Content="Visa Deltagare"
                    Command="{Binding btnEventInfo}"
                    Width="150"
                    Margin="0,0,10,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="5">


                <Button Content="Redigera"
        Command="{Binding btnEditEvent}"
        Width="150"
        Margin="0,0,10,0"/>

                <Button Content="Ta bort Aktivitet"
        Command="{Binding btnRemoveEvent}"
        Width="150"
        Margin="0,0,10,0"/>

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
