<UserControl x:Class="Laboration_2.View.UserControls.MenuBar.MenuBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Laboration_2.View.UserControls.MenuBar"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="300">
    <Grid>
        <Grid>
            <StackPanel Orientation="Horizontal">
                <Button Name="AddUser" Content="Ny Medlem" Margin="5" 
                Height="30" Click="AddUser_Click"/>
                <Button Name="NewSpel" Content="Nytt Spel" Margin="5" 
                Height="30" Click="NewSpel_Click"/>
                <Button Name="NewEvent" Content="Ny Aktivitet" Margin="5" 
                Height="30" Click="NewEvent_Click"/>
                <Button Name="btnTestData" Content="Test Data" Margin="5" 
                Height="30" Click="btnTestData_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
